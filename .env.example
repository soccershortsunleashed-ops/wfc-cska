# База данных
# SQLite для разработки (по умолчанию)
DATABASE_URL="file:./dev.db"

# PostgreSQL для production (раскомментируйте и настройте)
# DATABASE_URL="postgresql://username:password@localhost:5432/wfccska?schema=public"

# Опциональные переменные

# Base URL сайта (для metadata и SEO)
NEXT_PUBLIC_BASE_URL="http://localhost:3000"

# Google Analytics ID (если используется)
# NEXT_PUBLIC_GA_ID="G-XXXXXXXXXX"

# Yandex Metrika ID (если используется)
# NEXT_PUBLIC_YM_ID="XXXXXXXX"

# Bitrix24 Webhook URL (для интеграции)
# BITRIX24_WEBHOOK_URL="https://your-domain.bitrix24.ru/rest/1/xxxxx/"

# Режим разработки
NODE_ENV="development"
